# ─────────────────────────────────────────────────────────────────────────────
# Next-Gen-Rally-OS — environment contract
#
# Copy to `.env` at the repo root (or per-app) and fill in real values.
# Every variable below is consumed by one of the workspaces; see comments.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (Neon / Railway / local). Used by packages/core-data
# (Prisma datasource) and every app/service that reads the system of record.
DATABASE_URL="postgresql://user:password@localhost:5432/rally_os?schema=public"

# Claude API key for packages/ai (practice-plan builder + player-trend suggestions).
ANTHROPIC_API_KEY="sk-ant-..."

# next-auth canonical URL. MUST be a valid absolute URL or next-auth throws at
# build/runtime. CI sets this to http://localhost:3000 for the build step.
NEXTAUTH_URL="http://localhost:3000"

# next-auth session/JWT signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"

# SMTP connection string for the next-auth EmailProvider (magic-link sign in).
# Format: smtp://user:password@host:port
EMAIL_SERVER="smtp://user:password@smtp.example.com:587"

# From address used on magic-link / notification emails.
EMAIL_FROM="Rally-OS <no-reply@example.com>"

# Cron expression driving services/ncs-worker (NCS roster + tournament polling).
NCS_POLL_CRON="0 */6 * * *"

# Vercel deploy token used by apps/org-builder to publish public team sites.
VERCEL_TOKEN="..."
