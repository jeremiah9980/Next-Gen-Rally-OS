generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id        String       @id @default(cuid())
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  seasons   TeamSeason[]
}

model TeamSeason {
  id                             String                    @id @default(cuid())
  teamId                         String?
  isActive                       Boolean                   @default(true)
  team_name                      String
  season                         String
  age_group                      String
  organization                   String?
  head_coach                     String?
  assistant_coaches              String?
  practice_location              String?
  primary_game_location          String?
  team_standards                 String?                   @db.Text
  development_goals              String?                   @db.Text
  communication_expectations     String?                   @db.Text
  createdAt                      DateTime                  @default(now())
  updatedAt                      DateTime                  @updatedAt
  team                           Team?                     @relation(fields: [teamId], references: [id])
  rosterEntries                  RosterEntry[]
  gameChangerStatSnapshots       GameChangerStatSnapshot[]
  ncsPlayerSources               NcsPlayerSource[]
  ncsChangeReviews               NcsChangeReview[]
  tournamentEntries              NcsTournamentEntry[]
}

model Player {
  id                       String                    @id @default(cuid())
  firstName                String?
  lastName                 String?
  fullName                 String?
  jerseyNumber             String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  rosterEntries            RosterEntry[]
  gameChangerStatSnapshots GameChangerStatSnapshot[]
  ncsPlayerSources         NcsPlayerSource[]
  ncsChangeReviews         NcsChangeReview[]
}

model RosterEntry {
  id           String     @id @default(cuid())
  teamSeasonId String
  playerId     String
  jerseyNumber String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  player       Player     @relation(fields: [playerId], references: [id])
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id])
}

model GameChangerStatSnapshot {
  id           String     @id @default(cuid())
  teamSeasonId String
  playerId     String
  avg          Decimal?   @db.Decimal(5, 3)
  ab           Int?
  rbi          Int?
  hr           Int?
  capturedAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id])
  player       Player     @relation(fields: [playerId], references: [id])
}


enum NcsChangeStatus {
  change_detected
  pending_review
  accepted
  ignored
}

model NcsPlayerSource {
  id           String     @id @default(cuid())
  playerId     String
  teamSeasonId String
  ncsId        String?
  ncsTeamUrl   String?
  rawName      String
  rawJersey    String?
  rawPosition  String?
  lastSeenAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  player       Player     @relation(fields: [playerId], references: [id])
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id])

  @@unique([ncsId, teamSeasonId])
}

model NcsChangeReview {
  id           String          @id @default(cuid())
  teamSeasonId String
  playerId     String?
  ncsId        String?
  field        String
  oldValue     String?
  newValue     String?
  status       NcsChangeStatus @default(change_detected)
  reviewedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  teamSeason   TeamSeason      @relation(fields: [teamSeasonId], references: [id])
  player       Player?         @relation(fields: [playerId], references: [id])
}

model NcsTournament {
  id              String               @id @default(cuid())
  ncsId           String?              @unique
  name            String
  location        String?
  startDate       DateTime?
  endDate         DateTime?
  registrationUrl String?
  sourceUrl       String?
  rawMetadata     Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  entries         NcsTournamentEntry[]
}

model NcsTournamentEntry {
  id           String        @id @default(cuid())
  teamSeasonId String
  tournamentId String
  isRegistered Boolean       @default(false)
  attachedAt   DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  teamSeason   TeamSeason    @relation(fields: [teamSeasonId], references: [id])
  tournament   NcsTournament @relation(fields: [tournamentId], references: [id])

  @@unique([teamSeasonId, tournamentId])
}
