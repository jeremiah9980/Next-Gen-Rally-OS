# Database connection (required)
DATABASE_URL=******localhost:5432/rallyos

# Cron schedule for NCS roster and tournament polls (node-cron format).
# If omitted, the worker runs once immediately and exits.
# Examples:
#   Every hour on the hour:   0 * * * *
#   Every day at 6 AM:        0 6 * * *
#   Every 30 minutes:         */30 * * * *
NCS_POLL_CRON=0 * * * *
